# ── LLM ──
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Business Database (NL2SQL target) ──
BIZ_DB_HOST=localhost
BIZ_DB_PORT=3306
BIZ_DB_USER=root
BIZ_DB_PASSWORD=123456
BIZ_DB_NAME=ecommerce_demo

# ── Application Database (conversations, history) ──
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_USER=root
APP_DB_PASSWORD=123456
APP_DB_NAME=smart_analyst

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# ── Server ──
HOST=0.0.0.0
PORT=8001
